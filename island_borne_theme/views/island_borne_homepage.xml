<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="island_borne_homepage_template" model="ir.ui.view">
        <field name="name">Island Borne Original Homepage</field>
        <field name="key">island_borne_theme.island_borne_homepage_template</field>
        <field name="type">qweb</field>
        <field name="arch" type="xml">
            <t t-name="island_borne_theme.island_borne_homepage_template">
                <t t-call="website.layout">
                    <t t-set="title">Island Borne</t>
                    <t t-set="no_header" t-value="True"/>
                    <t t-set="no_footer" t-value="True"/>

<style type="text/css"><![CDATA[
@import url('https://fonts.googleapis.com/css2?family=Afacad:wght@400;500;600;700;800;900&family=Vampiro+One&display=swap');

:root {
    --ib-bg: #fff6ea;
    --ib-orange: #f05c40;
    --ib-orange-dark: #e84e36;
    --ib-lilac: #D5C2D8;
    --ib-yellow: #ffe982;
    --ib-black: #111111;
    --ib-white: #ffffff;
}

html:has(.ib-page),
body:has(.ib-page),
body.ib-island-page {
    margin: 0 !important;
    padding: 0 !important;
    background: var(--ib-bg) !important;
    overflow-x: hidden !important;
}

body:has(.ib-page) #wrapwrap > header,
body:has(.ib-page) #wrapwrap > footer,
body:has(.ib-page) .o_header_standard,
body:has(.ib-page) .o_header_affixed,
body:has(.ib-page) .o_footer,
body:has(.ib-page) header#top,
body:has(.ib-page) footer#bottom,
body.ib-island-page #wrapwrap > header,
body.ib-island-page #wrapwrap > footer,
body.ib-island-page .o_header_standard,
body.ib-island-page .o_header_affixed,
body.ib-island-page .o_footer,
body.ib-island-page header#top,
body.ib-island-page footer#bottom {
    display: none !important;
    visibility: hidden !important;
    height: 0 !important;
    min-height: 0 !important;
    overflow: hidden !important;
}

body:has(.ib-page) main,
body:has(.ib-page) #wrapwrap,
body:has(.ib-page) #wrap,
body.ib-island-page main,
body.ib-island-page #wrapwrap,
body.ib-island-page #wrap {
    margin: 0 !important;
    padding: 0 !important;
    max-width: none !important;
    width: 100% !important;
}

body:has(.ib-page) .container,
body.ib-island-page .container {
    max-width: none !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
}

.ib-page,
.ib-page * {
    box-sizing: border-box;
}

.ib-page {
    width: 100%;
    overflow-x: hidden;
    background: var(--ib-bg);
    color: var(--ib-orange);
    font-family: 'Afacad', Arial, sans-serif;
    font-size: 16px;
    line-height: 1.35;
}

.ib-topbar {
    height: 31px;
    background: var(--ib-orange);
    color: var(--ib-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Afacad', Arial, sans-serif;
    font-size: 10px;
    line-height: 1;
    font-weight: 800;
    letter-spacing: 8px;
    text-transform: uppercase;
    text-align: center;
}

.ib-header {
    height: 71px;
    background: var(--ib-bg);
    display: grid;
    grid-template-columns: minmax(170px, 1fr) minmax(360px, 560px) minmax(150px, 1fr);
    align-items: center;
    padding: 0 clamp(48px, 8vw, 150px);
    position: relative;
    z-index: 30;
}

.ib-mobile-menu-button {
    display: none;
}

.ib-logo-link {
    display: inline-flex;
    align-items: center;
    width: max-content;
    text-decoration: none;
}

.ib-logo {
    width: 154px;
    height: auto;
    display: block;
}

.ib-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(72px, 8.3vw, 145px);
}

.ib-nav a,
.ib-socials a,
.ib-footer a {
    color: var(--ib-orange);
    text-decoration: none;
}

.ib-nav a {
    font-size: 18px;
    line-height: 1;
    font-weight: 500;
    text-transform: lowercase;
}

.ib-socials {
    justify-self: end;
    display: flex;
    gap: 30px;
    align-items: center;
    color: var(--ib-orange);
}

.ib-socials a,
.ib-footer-socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.ib-socials svg {
    width: 24px;
    height: 24px;
    display: block;
}

.ib-socials a:hover,
.ib-nav a:hover,
.ib-footer a:hover {
    opacity: .78;
}

.ib-hero {
    display: grid;
    grid-template-columns: 47% 53%;
    min-height: 498px;
    background: var(--ib-bg);
    position: relative;
}

.ib-hero::after,
.ib-hero-copy::after,
.ib-story::after,
.ib-products-banner-wrap::after {
    content: "";
    position: absolute;
    left: -2%;
    right: -2%;
    bottom: -1px;
    height: 42px;
    background: var(--ib-bg);
    clip-path: polygon(0 63%, 6% 50%, 13% 58%, 22% 49%, 32% 61%, 42% 50%, 53% 65%, 63% 47%, 74% 60%, 84% 48%, 93% 60%, 100% 52%, 100% 100%, 0 100%);
    z-index: 8;
}

.ib-hero-copy {
    background: var(--ib-lilac);
    padding: 94px 70px 92px clamp(76px, 7.8vw, 150px);
    position: relative;
    z-index: 4;
}

.ib-hero-heading {
    width: min(420px, 88%);
    height: auto;
    display: block;
    margin: 0 0 34px;
}

.ib-hero-copy p {
    max-width: 405px;
    margin: 0 0 38px;
    color: var(--ib-orange);
    font-size: clamp(23px, 1.8vw, 28px);
    font-weight: 600;
    line-height: 1.16;
    letter-spacing: .1px;
}

.ib-btn {
    min-width: 205px;
    height: 55px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 28px;
    border-radius: 999px;
    background: var(--ib-orange);
    color: var(--ib-white) !important;
    text-decoration: none !important;
    border: 0;
    font-size: 22px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: .8px;
    text-transform: uppercase;
    transition: transform .18s ease, background .18s ease;
}

.ib-btn:hover {
    background: var(--ib-orange-dark);
    transform: translateY(-1px);
}

.ib-hero-visual {
    position: relative;
    min-height: 498px;
    overflow: hidden;
    background: #111;
}

.ib-hero-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transform: scale(1.02);
    transition: opacity .8s ease, transform 4.6s ease;
}

.ib-hero-slide.is-active {
    opacity: 1;
    transform: scale(1);
}

.ib-hero-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

/* Story / scent section */
.ib-story {
    position: relative;
    display: grid;
    grid-template-columns: 46% 54%;
    min-height: 930px;
    padding: 130px clamp(75px, 7vw, 145px) 100px;
    background: var(--ib-bg);
}

.ib-scent-panel {
    align-self: start;
}

.ib-scent-heading {
    width: min(545px, 95%);
    display: block;
    height: auto;
    margin: 0 0 45px;
}

.ib-scent-blob {
    width: min(700px, 98%);
    display: block;
    height: auto;
    margin-left: -45px;
}

.ib-story-copy {
    align-self: start;
    padding-left: 34px;
    padding-top: 12px;
}

.ib-story-copy h2 {
    max-width: 790px;
    margin: 0 0 55px;
    color: var(--ib-orange);
    font-size: clamp(36px, 3.25vw, 62px);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: .4px;
    text-transform: uppercase;
}

.ib-story-copy p {
    max-width: 820px;
    margin: 0 0 38px;
    color: var(--ib-orange);
    font-size: clamp(22px, 1.65vw, 31px);
    font-weight: 500;
    line-height: 1.16;
}

/* Products */
.ib-products-banner-wrap {
    position: relative;
    width: 100%;
    background: var(--ib-bg);
}

.ib-products-banner {
    width: 100%;
    height: auto;
    display: block;
}

.ib-products {
    background: var(--ib-bg);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    row-gap: 125px;
    column-gap: 80px;
    padding: 100px clamp(75px, 8vw, 150px) 150px;
}

.ib-product-card {
    text-align: center;
    color: var(--ib-black);
    display: flex;
    flex-direction: column;
    align-items: center;
}

.ib-product-card img {
    width: min(230px, 45vw);
    height: 315px;
    object-fit: contain;
    display: block;
    margin: 0 auto 26px;
}

.ib-product-card h3 {
    margin: 0 0 6px;
    color: var(--ib-black);
    font-size: clamp(25px, 1.9vw, 36px);
    font-weight: 900;
    line-height: .96;
    letter-spacing: .2px;
    text-transform: uppercase;
}

.ib-product-card p {
    margin: 0;
    color: var(--ib-orange);
    font-size: clamp(22px, 1.55vw, 31px);
    font-weight: 500;
    line-height: 1.1;
}

/* Store finder */
.ib-store-section {
    background: var(--ib-orange);
    color: var(--ib-white);
    padding: 80px clamp(75px, 7vw, 145px) 95px;
}

.ib-store-inner {
    max-width: 1700px;
    margin: 0 auto;
}

.ib-store-title-row {
    margin: 0 0 52px;
}

.ib-store-title-img-desktop {
    width: min(100%, 1695px);
    height: auto;
    display: block;
}

.ib-store-title-img-mobile {
    display: none;
}

.ib-store-grid {
    display: grid;
    grid-template-columns: 425px minmax(0, 1fr);
    gap: 34px;
    align-items: stretch;
}

.ib-store-sidebar {
    min-width: 0;
    display: flex;
    flex-direction: column;
}

.ib-search-wrap {
    display: grid;
    grid-template-columns: 1fr 58px;
    gap: 12px;
    height: 55px;
    margin-bottom: 28px;
}

.ib-search-wrap input {
    width: 100%;
    min-width: 0;
    border: 0;
    border-radius: 999px;
    background: var(--ib-bg);
    color: #75534b;
    font-family: 'Afacad', Arial, sans-serif;
    font-size: 21px;
    font-weight: 700;
    padding: 0 28px;
    outline: none;
}

.ib-search-wrap button {
    border: 0;
    border-radius: 7px;
    background: var(--ib-bg);
    color: var(--ib-orange);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
}

.ib-search-wrap button svg {
    width: 24px;
    height: 24px;
}

.ib-store-list {
    height: 555px;
    background: rgba(255,255,255,.12);
    border: 2px solid rgba(255,255,255,.8);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #fff1e5 rgba(255,255,255,.2);
}

.ib-store-card {
    width: 100%;
    border: 0;
    border-bottom: 1px solid rgba(240,92,64,.26);
    display: grid;
    grid-template-columns: 68px 1fr;
    gap: 22px;
    min-height: 172px;
    padding: 38px 32px;
    background: var(--ib-bg);
    color: var(--ib-orange);
    font-family: 'Afacad', Arial, sans-serif;
    cursor: pointer;
    text-align: left;
}

.ib-store-card.is-active,
.ib-store-card:hover {
    background: var(--ib-orange);
    color: var(--ib-white);
}

.ib-store-pin svg {
    width: 32px;
    height: 45px;
    display: block;
}

.ib-store-card h3 {
    margin: 0 0 6px;
    font-size: 25px;
    line-height: .98;
    font-weight: 800;
}

.ib-store-card p {
    margin: 0;
    font-size: 18px;
    line-height: 1.08;
    font-weight: 600;
}

.ib-map-wrap {
    position: relative;
    min-height: 638px;
    background: #92d7df;
    overflow: hidden;
}

.ib-google-map,
.ib-google-map iframe {
    width: 100%;
    height: 100%;
    min-height: 638px;
    border: 0;
    display: block;
}

.ib-google-map {
    position: relative;
}

.ib-map-fallback-notice {
    position: absolute;
    left: 16px;
    right: 16px;
    bottom: 14px;
    background: rgba(255,246,234,.88);
    color: #704c44;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 15px;
    font-weight: 700;
    pointer-events: none;
}

/* Footer */
.ib-footer {
    min-height: 420px;
    background-color: var(--ib-orange);
    background-image: url('/island_borne_theme/static/src/img/footer_pattern_sample_desktop.png');
    background-repeat: repeat;
    background-size: 1920px 180px;
    color: var(--ib-white);
    padding: 105px clamp(75px, 7vw, 145px) 22px;
}

.ib-footer-inner {
    max-width: 1700px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 145px 230px 1fr 440px;
    gap: 40px;
    align-items: start;
}

.ib-footer-logo {
    width: 105px;
    height: auto;
    display: block;
}

.ib-footer-menu {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.ib-footer-menu a {
    color: var(--ib-white);
    font-size: 25px;
    font-weight: 700;
    line-height: 1.05;
    text-transform: uppercase;
}

.ib-footer-address p {
    margin: 0;
    color: var(--ib-white);
    font-size: 23px;
    line-height: 1.06;
    font-weight: 600;
}

.ib-newsletter-form {
    display: grid;
    grid-template-columns: 1fr 58px;
    gap: 8px;
    height: 36px;
    margin-bottom: 20px;
}

.ib-newsletter-form input {
    border: 0;
    border-radius: 999px;
    background: var(--ib-bg);
    color: #7d5d55;
    padding: 0 22px;
    font-size: 16px;
    font-family: 'Afacad', Arial, sans-serif;
    font-weight: 600;
    outline: none;
}

.ib-newsletter-form button {
    border: 0;
    border-radius: 6px;
    background: var(--ib-bg);
    color: var(--ib-orange);
    font-size: 28px;
    line-height: 1;
    font-weight: 800;
    cursor: pointer;
}

.ib-newsletter h3 {
    margin: 0;
    color: var(--ib-white);
    font-size: 37px;
    line-height: .9;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
}

.ib-newsletter p {
    margin: 6px 0 16px;
    color: var(--ib-white);
    font-size: 18px;
    font-weight: 600;
    line-height: 1;
}

.ib-footer-socials {
    display: flex;
    gap: 17px;
    align-items: center;
}

.ib-footer-socials a {
    color: var(--ib-white);
}

.ib-footer-socials svg {
    width: 24px;
    height: 24px;
}

.ib-copyright {
    max-width: 1700px;
    margin: 50px auto 0;
    color: var(--ib-white);
    font-size: 13px;
    line-height: 1;
    font-weight: 600;
    text-align: center;
}

@media (max-width: 1100px) {
    .ib-header {
        padding-left: 44px;
        padding-right: 44px;
    }
    .ib-logo { width: 130px; }
    .ib-nav { gap: 65px; }
    .ib-nav a { font-size: 16px; }
    .ib-hero-copy {
        padding-left: 58px;
        padding-right: 48px;
    }
    .ib-store-grid {
        grid-template-columns: 340px minmax(0, 1fr);
    }
    .ib-store-card {
        grid-template-columns: 52px 1fr;
        padding: 28px 24px;
    }
}

/* Mobile mockup-specific order and layout */
@media (max-width: 767px) {
    .ib-topbar {
        height: 39px;
        padding: 0 16px;
        font-size: 8px;
        letter-spacing: 5px;
    }

    .ib-header {
        height: 136px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 34px;
        position: relative;
    }

    .ib-mobile-menu-button {
        display: flex;
        position: absolute;
        left: 36px;
        top: 50%;
        transform: translateY(-50%);
        width: 54px;
        height: 48px;
        border: 0;
        background: transparent;
        padding: 0;
        align-items: center;
        justify-content: center;
        color: var(--ib-orange);
        cursor: pointer;
        z-index: 40;
    }

    .ib-mobile-menu-button span,
    .ib-mobile-menu-button span::before,
    .ib-mobile-menu-button span::after {
        content: "";
        display: block;
        width: 48px;
        height: 6px;
        border-radius: 999px;
        background: currentColor;
        position: relative;
    }

    .ib-mobile-menu-button span::before,
    .ib-mobile-menu-button span::after {
        position: absolute;
        left: 0;
    }

    .ib-mobile-menu-button span::before { top: -16px; }
    .ib-mobile-menu-button span::after { top: 16px; }

    .ib-logo {
        width: 248px;
        max-width: 54vw;
    }

    .ib-nav {
        position: absolute;
        left: 0;
        right: 0;
        top: 100%;
        display: none;
        flex-direction: column;
        gap: 0;
        background: var(--ib-bg);
        border-top: 1px solid rgba(240,92,64,.22);
        box-shadow: 0 15px 25px rgba(0,0,0,.08);
        z-index: 35;
    }

    .ib-page.is-mobile-menu-open .ib-nav {
        display: flex;
    }

    .ib-nav a {
        display: block;
        padding: 18px 34px;
        border-bottom: 1px solid rgba(240,92,64,.14);
        font-size: 22px;
        text-align: left;
    }

    .ib-socials {
        display: none;
    }

    .ib-hero {
        display: flex;
        flex-direction: column-reverse;
        min-height: 0;
    }

    .ib-hero::after {
        display: none;
    }

    .ib-hero-visual {
        min-height: 0;
        height: auto;
    }

    .ib-hero-slide {
        position: relative;
        inset: auto;
        display: none;
        opacity: 1;
        transform: none;
        transition: none;
    }

    .ib-hero-slide.is-active {
        display: block;
    }

    .ib-hero-slide img {
        height: auto;
        min-height: 0;
        object-fit: contain;
    }

    .ib-hero-slide img.ib-desktop-hero-img {
        display: none;
    }

    .ib-hero-slide img.ib-mobile-hero-img {
        display: block;
        width: 100%;
    }

    .ib-hero-copy {
        padding: 75px 21vw 72px;
        background: var(--ib-lilac);
        text-align: left;
    }

    .ib-hero-copy::before,
    .ib-hero-copy::after {
        content: "";
        position: absolute;
        left: -2%;
        right: -2%;
        height: 38px;
        background: var(--ib-lilac);
        clip-path: polygon(0 48%, 9% 58%, 20% 44%, 32% 55%, 45% 47%, 58% 60%, 70% 50%, 82% 60%, 94% 52%, 100% 58%, 100% 100%, 0 100%);
        z-index: 2;
    }

    .ib-hero-copy::before {
        top: -37px;
    }

    .ib-hero-copy::after {
        bottom: -37px;
        background: var(--ib-bg);
        clip-path: polygon(0 48%, 9% 58%, 20% 44%, 32% 55%, 45% 47%, 58% 60%, 70% 50%, 82% 60%, 94% 52%, 100% 58%, 100% 100%, 0 100%);
    }

    .ib-hero-heading {
        width: min(475px, 100%);
        margin: 0 0 36px;
    }

    .ib-hero-copy p {
        max-width: 520px;
        margin: 0 0 46px;
        font-size: clamp(22px, 5vw, 40px);
        line-height: 1.16;
        font-weight: 600;
    }

    .ib-btn {
        min-width: 262px;
        height: 67px;
        font-size: 25px;
        letter-spacing: 1px;
    }

    .ib-story {
        display: flex;
        flex-direction: column;
        min-height: 0;
        padding: 110px 50px 0;
    }

    .ib-story::after {
        display: none;
    }

    .ib-scent-panel {
        order: 1;
        text-align: center;
        margin: 0 auto 58px;
        width: 100%;
    }

    .ib-scent-heading {
        width: min(610px, 100%);
        margin: 0 auto 45px;
    }

    .ib-scent-blob {
        width: min(880px, 100%);
        margin: 0 auto;
    }

    .ib-story-copy {
        order: 4;
        padding: 92px 8px 70px;
    }

    .ib-story-copy h2 {
        max-width: none;
        margin: 0 0 45px;
        font-size: clamp(28px, 6.5vw, 47px);
        line-height: 1.06;
        font-weight: 600;
    }

    .ib-story-copy p {
        max-width: none;
        margin: 0 0 32px;
        font-size: clamp(19px, 4.2vw, 29px);
        line-height: 1.16;
        font-weight: 500;
    }

    .ib-products-banner-wrap {
        margin-top: 0;
    }

    .ib-products-banner-desktop {
        display: none;
    }

    .ib-products-banner-mobile {
        display: block !important;
        width: 100%;
        height: auto;
    }

    .ib-products-banner-wrap::after {
        height: 30px;
    }

    .ib-products {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 80px 28px;
        padding: 80px 46px 74px;
    }

    .ib-product-card img {
        width: min(215px, 38vw);
        height: 300px;
        margin-bottom: 20px;
    }

    .ib-product-card h3 {
        font-size: clamp(19px, 5vw, 32px);
        line-height: .98;
        margin-bottom: 5px;
    }

    .ib-product-card p {
        font-size: clamp(17px, 4.4vw, 28px);
    }

    .ib-product-cool-shower { order: 3; }
    .ib-product-juicy-shower { order: 1; }
    .ib-product-yummy-shower { order: 2; }
